<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.ifpr.androidapptemplate.ui.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_estatisticas"
        android:name="com.ifpr.androidapptemplate.ui.estatisticas.EstatisticasFragment"
        android:label="@string/title_estatisticas"
        tools:layout="@layout/fragment_estatisticas" />

    <fragment
        android:id="@+id/navigation_historico"
        android:name="com.ifpr.androidapptemplate.ui.historico.HistoricoFragment"
        android:label="@string/title_historico"
        tools:layout="@layout/fragment_historico" />

    <fragment
        android:id="@+id/navigation_admin"
        android:name="com.ifpr.androidapptemplate.ui.admin.AdminFragment"
        android:label="@string/title_admin"
        tools:layout="@layout/fragment_admin" />

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.ifpr.androidapptemplate.ui.settings.SettingsFragment"
        android:label="@string/title_settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/navigation_about"
        android:name="com.ifpr.androidapptemplate.ui.about.AboutFragment"
        android:label="@string/title_about"
        tools:layout="@layout/fragment_about" />

</navigation>